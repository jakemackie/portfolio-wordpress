{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "blocks/build",
    "rootDir": "blocks/src",
    "types": [
      "@wordpress/blocks",
      "@wordpress/block-editor",
      "@wordpress/components"
    ]
  },
  "include": ["blocks/src/**/*"]
}
