{
    "$schema": "https://raw.githubusercontent.com/WordPress/gutenberg/trunk/schemas/json/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "align": ["wide", "full"],
        "layout": {
            "contentSize": "1440px",
            "wideSize": "1920px"
        },
        "typography": {
            "defaultFontSizes": false,
            "fontSizes": [
                { "name": "Small", "slug": "small", "size": "0.875rem" },
                { "name": "Medium", "slug": "medium", "size": "1rem" },
                { "name": "Large", "slug": "large", "size": "1.5rem" },
                { "name": "XL", "slug": "x-large", "size": "2rem" },
                { "name": "XXL", "slug": "xx-large", "size": "clamp(2.5rem, 6vw, 4rem)" },
                { "name": "Giant", "slug": "giant", "size": "clamp(3rem, 7vw, 5rem)" }
            ],
            "fontFamilies": [
                {
                    "fontFamily": "'Manrope', sans-serif",
                    "slug": "manrope",
                    "name": "Manrope",
                    "fontFace": [
                        {
                            "fontFamily": "Manrope",
                            "fontWeight": "100 900",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [ "file:./assets/fonts/Manrope/ManropeVariable.woff2" ]
                        }
                    ]
                },
                {
                    "fontFamily": "'Inter', sans-serif",
                    "slug": "inter",
                    "name": "Inter",
                    "fontFace": [
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "100 900",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [ "file:./assets/fonts/Inter/InterVariable.woff2" ]
                        },
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "100 900",
                            "fontStyle": "italic",
                            "fontDisplay": "swap",
                            "src": [ "file:./assets/fonts/Inter/InterVariable-Italic.woff2" ]
                        }
                    ]
                }
            ]
        },
        "color": {
            "palette": [
                { "slug": "primary-100", "color": "#FFFFFF", "name": "Primary (100)" },
                { "slug": "primary-200", "color": "#F1F0F1", "name": "Primary (200)" },
                { "slug": "primary-300", "color": "#E3E2E3", "name": "Primary (300)" },
                { "slug": "primary-400", "color": "#C6C6C7", "name": "Primary (400)" },
                { "slug": "primary-500", "color": "#ABABAC", "name": "Primary (500)" },
                { "slug": "secondary-100", "color": "#EAF1FF", "name": "Secondary (100)" },
                { "slug": "secondary-200", "color": "#D4E4FA", "name": "Secondary (200)" },
                { "slug": "secondary-300", "color": "#B9C8DE", "name": "Secondary (300)" },
                { "slug": "secondary-400", "color": "#9DACC2", "name": "Secondary (400)" },
                { "slug": "secondary-500", "color": "#8392A7", "name": "Secondary (500)" },
                { "slug": "tertiary-100", "color": "#717783", "name": "Tertiary (100)" },
                { "slug": "tertiary-200", "color": "#5B6170", "name": "Tertiary (200)" },
                { "slug": "tertiary-300", "color": "#414752", "name": "Tertiary (300)" },
                { "slug": "tertiary-400", "color": "#2A313B", "name": "Tertiary (400)" },
                { "slug": "tertiary-500", "color": "#151C26", "name": "Tertiary (500)" },
                { "slug": "neutral-100", "color": "#5F5E5E", "name": "Neutral (100)" },
                { "slug": "neutral-200", "color": "#474646", "name": "Neutral (200)" },
                { "slug": "neutral-300", "color": "#313030", "name": "Neutral (300)" },
                { "slug": "neutral-400", "color": "#1C1B1B", "name": "Neutral (400)" },
                { "slug": "neutral-500", "color": "#0A0A0A", "name": "Neutral (500)" }
            ]
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "spacingSizes": [
                { "name": "3xs", "slug": "3xs", "size": "0.25rem" },
                { "name": "2xs", "slug": "2xs", "size": "0.5rem" },
                { "name": "Xs", "slug": "xs", "size": "0.75rem" },
                { "name": "Small", "slug": "small", "size": "clamp(1rem, 2vw, 1.5rem)" },
                { "name": "Medium", "slug": "medium", "size": "clamp(2rem, 5vw, 4rem)" },
                { "name": "Large", "slug": "large", "size": "clamp(4rem, 8vw, 7rem)" },
                { "name": "X-Large", "slug": "x-large", "size": "clamp(6rem, 12vw, 10rem)" }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--neutral-500)",
            "text": "var(--wp--preset--color--primary-500)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--inter)",
            "fontSize": "16px",
            "color": "var(--wp--preset--color--primary-500)",
            "lineHeight": "1.6"
        },
        "blocks": {
            "core/heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--manrope)",
                    "fontWeight": "900",
                    "lineHeight": "1"
                },
                "color": {
                    "text": "var(--wp--preset--color--primary-100)"
                }
            },
            "core/button": {
                "typography": {
                    "fontSize": "14px",
                    "fontWeight": "600",
                    "textTransform": "uppercase"
                },
                "border": {
                    "radius": "0.25rem"
                },
                "spacing": {
                    "padding": {
                        "top": "0.6rem",
                        "bottom": "0.6rem",
                        "left": "1.2rem",
                        "right": "1.2rem"
                    }
                }
            }
        }
    },
    "elements": {
        "h1": {
            "typography": {
                "fontSize": "var(--wp--preset--font-size--giant)",
                "lineHeight": "1",
                "letterSpacing": "-0.02em"
            }
        }
    }
}