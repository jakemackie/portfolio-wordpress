{
    "$schema": "https://raw.githubusercontent.com/WordPress/gutenberg/trunk/schemas/json/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "1000px",
            "wideSize": "1400px"
        },
        "color": {
            "palette": [
                {
                    "slug": "black",
                    "color": "#000000",
                    "name": "Black"
                },
                {
                    "slug": "white",
                    "color": "#FFFFFF",
                    "name": "White"
                },
                {
                    "slug": "black-ice",
                    "color": "#0c0c0e",
                    "name": "Black Ice"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "'Inter', sans-serif",
                    "slug": "inter",
                    "name": "Inter",
                    "fontFace": [
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "100 900",
                            "fontStyle": "normal",
                            "fontDisplay": "swap",
                            "src": [ "file:./assets/fonts/Inter/InterVariable.woff2" ]
                        },
                        {
                            "fontFamily": "Inter",
                            "fontWeight": "100 900",
                            "fontStyle": "italic",
                            "fontDisplay": "swap",
                            "src": [ "file:./assets/fonts/Inter/InterVariable-Italic.woff2" ]
                        }
                    ]
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--black-ice)",
            "text": "var(--wp--preset--color--white)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--inter)",
            "fontSize": "16px",
            "lineHeight": "1.6"
        },
        "spacing": {
            "blockGap": "2rem",
            "padding": {
                "top": "var(--wp--preset--spacing--50)",
                "bottom": "var(--wp--preset--spacing--50)",
                "left": "1.5rem",
                "right": "1.5rem"
            }
        },
        "blocks": {
            "jakemackie/card": {
                "spacing": {
                    "padding": {
                        "top": "20px",
                        "right": "20px",
                        "bottom": "20px",
                        "left": "20px"
                    }
                },
                "border": {
                    "width": "1px",
                    "style": "solid",
                    "color": "#ccc",
                    "radius": "8px"
                }
            }
        }
    }
}