# MacOS specific ignores
.DS_Store

# Ignore everything
/*

# Except these folders
!.github/
!docker/
!wp-content/
!.gitignore


# Inside wp-content, ignore everything except your theme
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/wordpress/

# Ignore compiled assets and dependencies
wp-content/themes/wordpress/node_modules/
wp-content/themes/wordpress/blocks/build/

# Database
keys/
.env.local
*.sql
